\contentsline {figure}{\numberline {3.1}{\ignorespaces Operating principle of the current-mirror Flash ADC (CMF-ADC): (a) equilibrium operation, (b) signal operation, and (c) current-to-code conversion with asymmetric mirror ratios.}}{41}{figure.caption.87}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Transistor-level schematic of the first architecture, the current-mirror Flash ADC, showing the differential input pair driven by $V_\mathrm {ref}$ and $V_\mathrm {in}$, the tail current source $I_B$ and the five current-mirror output branches whose PMOS and NMOS width ratios set the thermometer thresholds $C[4]$ down to $C[0]$.}}{44}{figure.caption.90}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Transient response of the simulated current comparators to the same input current step, showing the output voltage together with the input and reference currents against time, from which the propagation delay is measured: (a) current-mirror, (b) Traff, (c) Lu Chen. The remaining three topologies are shown in Figure~\ref {fig:comp_operation_b}.}}{47}{figure.caption.92}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Transient response of the simulated current comparators, continued from Figure~\ref {fig:comp_operation}: (d) hysteresis, (e) Min and Kim, (f) CC-II based.}}{48}{figure.caption.93}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Simulated operation of the first architecture. The five comparator outputs (top) follow a trapezoidal input crossing the $0.4$~V reference (bottom). The rising crossing is tracked sharply, but the falling transition lags well behind the input crossing, the slow-recovery asymmetry of the high-impedance current-mirror node.}}{49}{figure.caption.94}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Complementary dual-input current-mirror OTA of the second approach, with the function of each transistor annotated: NMOS and PMOS input pairs, tail sources, mirror loads and cross-coupled output branches.}}{51}{figure.caption.95}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Simulated DC response of the second-architecture stage. The complementary outputs (out\_nmos, out\_pmos) and the internal node voltages never reach the supply rails and the transfer is visibly non-linear, the headroom shortfall predicted by equation~\eqref {eq:headroom_phase2} at the $0.8$~V supply.}}{53}{figure.caption.96}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Low-voltage cascode current mirror used at the tail of the OTAs, after Razavi~\blx@tocontentsinit {0}\cite {razavi}. The reference current $I_1$ feeds the $M_0$--$M_1$ branch and the output branch $M_2$--$M_3$ carries $I_\mathrm {out}$. The cascode devices $M_0$ and $M_3$, biased by $V_b$, hold the drains of the mirror devices, nodes $A$ and $B$, at equal voltage, so the current copies accurately while each node sits at only about one overdrive above ground.}}{54}{figure.caption.97}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces Bulk-driven OTA of the third architecture~\blx@tocontentsinit {0}\cite {ballo2022}, with the function of each transistor annotated, the non-tailed bulk-driven input pair $M_1$, $M_2$, the current-mirror loads and the cross-coupled load $M_7$, $M_8$ that provides the local positive feedback. The circled points 1 and 2 mark the two differential output nodes and point 3 the supply-side node of the input pair.}}{55}{figure.caption.98}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces Response of the bulk-driven OTA follower across the four process corners (FF, FS, SF, SS). The output waveform diverges markedly between corners, most of all near the lower rail, the sensitivity that led to discarding the architecture.}}{56}{figure.caption.102}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces Input-referred hysteresis of the bulk-driven OTA follower at the four process corners, measured under the $9$~MHz full-scale sinusoid, with the worst case marked at the slow SS corner.}}{57}{figure.caption.109}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces Final architecture, a complementary pair of five-transistor OTAs with the function of each transistor annotated, including the low-voltage tail mirrors and the current-mirror active loads.}}{59}{figure.caption.116}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces Open-loop magnitude and phase response of the complementary five-transistor OTA, showing the single dominant pole and the wide phase margin.}}{62}{figure.caption.123}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces DNL per code (left) and INL per transition (right) of the final architecture at the typical (TT) corner.}}{66}{figure.caption.129}%
